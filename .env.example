# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Adzuna
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key

# Claude AI
ANTHROPIC_API_KEY=your_anthropic_api_key

# Database (SQLite for dev, PostgreSQL for prod)
# DATABASE_URL=sqlite+aiosqlite:///./pipka.db
DATABASE_URL=sqlite+aiosqlite:///./pipka.db

# Optional: PostgreSQL for production
# DATABASE_URL=postgresql+asyncpg://pipka:pass@localhost:5432/pipka
# POSTGRES_PASSWORD is required when running via docker-compose with the postgres service.
# docker-compose.yml interpolates it into both POSTGRES_PASSWORD and DATABASE_URL.
# Generate with:  python3 -c "import secrets,string; print(''.join(secrets.choice(string.ascii_letters+string.digits) for _ in range(28)))"
POSTGRES_PASSWORD=change_me_strong_random_password

# Arbeitsagentur API (public, no registration needed)
ARBEITSAGENTUR_API_KEY=jobboerse-jobsuche

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
SESSION_SECRET=change_me_in_production

# Admin emails (comma-separated) — these Google accounts get admin role
ADMIN_EMAILS=your@email.com

# Logging
LOG_LEVEL=INFO

# Max job age for auto-cleanup (days)
JOB_MAX_AGE_DAYS=45
