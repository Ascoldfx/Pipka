# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Adzuna
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key

# Claude AI
ANTHROPIC_API_KEY=your_anthropic_api_key

# Database (SQLite for dev, PostgreSQL for prod)
# DATABASE_URL=sqlite+aiosqlite:///./jobhunt.db
DATABASE_URL=sqlite+aiosqlite:///./jobhunt.db

# Optional: PostgreSQL for production
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/jobhunt

# Arbeitsagentur API (public, no registration needed)
ARBEITSAGENTUR_API_KEY=jobboerse-jobsuche

# Dashboard Authentication (REQUIRED)
# Use strong, unique passwords. Never commit real values.
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change_me_to_a_strong_password
GUEST_USERNAME=guest
GUEST_PASSWORD=change_me_too

# Logging
LOG_LEVEL=INFO
